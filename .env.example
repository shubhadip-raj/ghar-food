# ─── Supabase ──────────────────────────────────────────────
# Get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Email via Resend ─────────────────────────────────────
# Get a free API key at https://resend.com  (3000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in Resend
EMAIL_FROM=noreply@ghar.food

# ─── Admin credentials (initial setup) ───────────────────
ADMIN_EMAIL=adam@ghar.food
ADMIN_PASSWORD=Billion$dream!

# ─── JWT Secret (generate any random 32+ char string) ─────
JWT_SECRET=change-this-to-a-random-secret-string-32chars

# ─── App URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
